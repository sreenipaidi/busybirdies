# =============================================================================
# SupportDesk Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://supportdesk:supportdesk@localhost:5432/supportdesk

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change-me-to-a-256-bit-secret-in-production
JWT_ISSUER=supportdesk
JWT_EMPLOYEE_EXPIRY=8h
JWT_CLIENT_EXPIRY=24h

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@helpdesk.com
SENDGRID_INBOUND_WEBHOOK_SECRET=xxx

# ---- File Storage (S3-Compatible) ----
S3_BUCKET=supportdesk-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000

# ---- Application ----
PLATFORM_DOMAIN=helpdesk.com
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
